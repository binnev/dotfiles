{
	// Place your snippets for go here. Each snippet is defined under a snippet name and has a prefix, body and 
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
	"Advent of Code day": {
		"prefix": "aoc-day",
		"body": [
			"package _20$1",
			"func Day$2Part1(input string) string {",
			"\treturn \"\"",
			"}",
			"func Day$2Part2(input string) string {",
			"\treturn \"\"",
			"}",
		]
	},
	"Advent of Code registry": {
		"prefix": "aoc-registry",
		"body": [
			"{20$1, $2, 1}: _20$1.Day$2Part1,",
			"{20$1, $2, 2}: _20$1.Day$2Part2,",
		]
	},
	"Test": {
		"prefix": "test",
		"body": [
			"func Test_$1(t *testing.T) {",
			"\t$2",
			"}",
		]
	},
	"Parametrized test": {
		"prefix": "param",
		"body": [
			"func Test_$1(t *testing.T) {",
			"\ttestcases := []struct {",
			"\t\t$2",
			"\t}{",
			"\t\t$5",
			"\t}",
			"\tfor _, tc := range testcases {",
			"\t\tt.Run($3, func(t *testing.T) {",
			"\t\t\t$4",
			"\t\t})",
			"\t}",
			"}",
		]
	}
}